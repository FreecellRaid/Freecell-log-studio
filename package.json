{
    "name": "freecell-log-studio",
    "private": true,
    "version": "1.0.0",
    "packageManager": "pnpm@11.2.2",
    "type": "module",
    "scripts": {
        "preinstall": "npx only-allow pnpm",
        "dev": "vite",
        "build": "vue-tsc -b && vite build",
        "build:single": "export VITE_SINGLE_FILE=true && vue-tsc -b && vite build",
        "preview": "vite preview",
        "format": "prettier --write ."
    },
    "dependencies": {
        "@lucide/vue": "^1.7.0",
        "@vueuse/core": "^14.3.0",
        "docx": "^9.6.1",
        "pinia": "^3.0.4",
        "vue": "^3.5.30",
        "vue-virtual-scroller": "^2.0.1"
    },
    "devDependencies": {
        "@types/node": "^24.12.2",
        "@vitejs/plugin-vue": "^6.0.5",
        "@vue/tsconfig": "^0.9.0",
        "prettier": "^3.8.1",
        "typescript": "~5.9.3",
        "vite": "^8.0.1",
        "vite-plugin-singlefile": "^2.3.3",
        "vue-tsc": "^3.2.5"
    }
}
